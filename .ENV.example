# Sample environment for Meme Wrangler Docker stack.
# Copy to `.ENV` and adjust secrets before deploying.
TELEGRAM_BOT_TOKEN=
OWNER_ID=0
CHANNEL_ID=
# MEMEBOT_ADMIN_CHANNEL_ID=
POSTGRES_DB=meme_wrangler
POSTGRES_USER=meme
POSTGRES_PASSWORD=meme
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
MEMEBOT_BACKUP_DIR=/app/backups
# MEMEBOT_RUNTIME_DIR=/app/runtime
# MEMEBOT_CACHE_DIR=/app/cache
# MEMEBOT_LOG_DIR=/app/logs
# MEMEBOT_DB_LIMIT=500mb
# MEMEBOT_SQLITE_PATH=/app/runtime/memebot.sqlite3
# MEMEBOT_ACTIVE_DB=primary
# MEMEBOT_DB_PROFILES={"primary":{"kind":"postgresql","label":"Primary Postgres","url":"postgresql://meme:meme@postgres:5432/meme_wrangler"},"sqlite":{"kind":"sqlite","label":"Local SQLite","path":"/app/runtime/memebot.sqlite3"}}
