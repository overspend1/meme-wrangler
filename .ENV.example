# Sample environment for Meme Wrangler Docker stack.
# Copy to `.ENV` and adjust secrets before deploying.
TELEGRAM_BOT_TOKEN=
OWNER_ID=0
CHANNEL_ID=

# --- Database ---
# For local Docker Compose (default):
POSTGRES_DB=meme_wrangler
POSTGRES_USER=meme
POSTGRES_PASSWORD=meme
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# For Neon DB (set DATABASE_URL and leave POSTGRES_HOST empty):
# DATABASE_URL=postgresql://user:pass@ep-cool-name-123456.us-east-2.aws.neon.tech/neondb?sslmode=require

# --- Backup ---
MEMEBOT_BACKUP_DIR=/app/backups
# MEMEBOT_BACKUP_PASSWORD_HASH=
# MEMEBOT_BACKUP_INTERVAL_HOURS=6
# MEMEBOT_BACKUP_RETAIN_COUNT=10
# MEMEBOT_BACKUP_STORE_IN_DB=true
