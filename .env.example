# Environment variables for the bot
# Copy this file to .env and fill in your actual values

TELEGRAM_BOT_TOKEN=your_bot_token_here
# Comma-separated list of owner Telegram user IDs (e.g., 123456789,987654321)
OWNER_ID=your_telegram_user_id_here
CHANNEL_ID=@your_channel_or_id_here
# Optional: separate admin alert channel or private admin group
# MEMEBOT_ADMIN_CHANNEL_ID=@your_admin_channel_or_id_here
# PostgreSQL connection string (format: postgresql://user:password@host:port/database)
DATABASE_URL=postgresql://meme:meme@localhost:5432/meme_wrangler
# Docker Compose overrides these defaults; adjust if you change the compose file
POSTGRES_DB=meme_wrangler
POSTGRES_USER=meme
POSTGRES_PASSWORD=meme
# Optional: multi-profile database control for in-bot migrate/switch buttons.
# Example:
# MEMEBOT_DB_PROFILES={"neon":{"kind":"postgresql","label":"Neon","url":"postgresql://..."}, "sqlite":{"kind":"sqlite","label":"Local SQLite","path":"/app/runtime/memebot.sqlite3"}}
# MEMEBOT_ACTIVE_DB=neon
# Optional: storage limit hint for /storage forecasting (examples: 500mb, 5gb)
# MEMEBOT_DB_LIMIT=500mb
# MEMEBOT_SQLITE_PATH=/app/runtime/memebot.sqlite3
# Optional: override backup directory path
# MEMEBOT_BACKUP_DIR=/path/to/backups
# Optional: runtime/cache/log directories used for bot-managed state and storage accounting
# MEMEBOT_RUNTIME_DIR=/path/to/runtime
# MEMEBOT_CACHE_DIR=/path/to/cache
# MEMEBOT_LOG_DIR=/path/to/logs
# Optional: override backup secret hash (SHA-256)
# MEMEBOT_BACKUP_PASSWORD_HASH=your_sha256_hash_here
